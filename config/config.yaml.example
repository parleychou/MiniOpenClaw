# config/config.yaml.example
# Configuration file template - Copy to config.yaml and fill in your actual configuration

feishu:
  # Feishu application credentials (obtain from Feishu Open Platform)
  app_id: "your_app_id_here"
  app_secret: "your_app_secret_here"
  verification_token: "your_verification_token"
  encrypt_key: "your_encrypt_key"  # Optional, for message encryption
  
  # Connection mode: "websocket" (recommended, no public URL needed) or "webhook" (requires public URL)
  connection_mode: "websocket"
  
  # Feishu bot webhook (for proactive message pushing, optional)
  # webhook_url: "https://open.feishu.cn/open-apis/bot/v2/hook/your_hook_id"
  
  # Event subscription callback port
  server_port: 9980
  
  # Allowed user ID list (security control)
  # If empty or commented out, all users are allowed
  # To get user ID: Check event logs in Feishu Open Platform
  allowed_users:
    # - "ou_xxxxxxxxxxxxx"  # Replace with your actual user ID
    # - "ou_yyyyyyyyyyyyy"  # You can add multiple users

agent:
  # Default agent to use: claude_code or opencode
  default: "claude_code"
  
  claude_code:
    # Claude Code CLI command path
    # Windows: Usually at C:/Users/YourName/AppData/Roaming/npm/claude.cmd
    # Linux/Mac: Usually at /usr/local/bin/claude or ~/.local/bin/claude
    command: "claude"
    
    # Working directory - Agent will execute operations in this directory
    work_dir: "D:/projects/my-project"
    
    # Startup arguments
    args: ["--dangerously-skip-permissions"]
  
  opencode:
    # OpenCode CLI command path
    command: "opencode"
    work_dir: "D:/projects/my-project"
    args: []

monitor:
  # Status check interval (seconds)
  check_interval: 5
  
  # Timeout alert threshold (seconds) - Alert will be sent if command execution exceeds this time
  timeout_threshold: 300
  
  # Heartbeat reporting interval (seconds)
  heartbeat_interval: 60

output_filter:
  # Key patterns to forward to Feishu (regular expressions)
  forward_patterns:
    - "confirm|yes/no|Y/n|y/N"
    - "Error|failed"
    - "Done|Success"
    - "Created|Modified|Deleted"
    - "Warning"
    - "\\? |Select|Choose"
  
  # Patterns to ignore (regular expressions)
  ignore_patterns:
    - "⠋|⠙|⠹|⠸|⠼|⠴|⠦|⠧|⠇|⠏"  # Loading animations
    - "^\\s*$"  # Empty lines
    - "thinking|Thinking"  # Thinking process
  
  # Maximum message length (characters)
  max_message_length: 2000
  
  # Message deduplication configuration
  dedup_enabled: true  # Enable message deduplication
  dedup_similarity_threshold: 0.90  # Similarity threshold (0.0-1.0), messages above this are considered duplicates
